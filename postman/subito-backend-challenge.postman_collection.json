{
  "info": {
    "name": "Subito Backend Challenge",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Products",
      "item": [
        {
          "name": "List all products",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/products"
          }
        },
        {
          "name": "Get product by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/products/{{productId}}"
          }
        },
        {
          "name": "Get product by ID (not found)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/products/nonexistent"
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Create order",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.id) {",
                  "  pm.collectionVariables.set('orderId', json.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    { \"productId\": \"prod-1\", \"quantity\": 1 },\n    { \"productId\": \"prod-5\", \"quantity\": 2 }\n  ]\n}"
            },
            "url": "{{baseUrl}}/orders"
          }
        },
        {
          "name": "Create order (mixed VAT rates)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.id) {",
                  "  pm.collectionVariables.set('orderId', json.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    { \"productId\": \"prod-2\", \"quantity\": 1 },\n    { \"productId\": \"prod-4\", \"quantity\": 3 },\n    { \"productId\": \"prod-5\", \"quantity\": 1 }\n  ]\n}"
            },
            "url": "{{baseUrl}}/orders"
          }
        },
        {
          "name": "Get order by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/orders/{{orderId}}"
          }
        },
        {
          "name": "List all orders",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/orders"
          }
        },
        {
          "name": "Create order (validation error — empty items)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": []\n}"
            },
            "url": "{{baseUrl}}/orders"
          }
        },
        {
          "name": "Create order (validation error — invalid quantity)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    { \"productId\": \"prod-1\", \"quantity\": 0 }\n  ]\n}"
            },
            "url": "{{baseUrl}}/orders"
          }
        },
        {
          "name": "Create order (not found — unknown product)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    { \"productId\": \"nonexistent\", \"quantity\": 1 }\n  ]\n}"
            },
            "url": "{{baseUrl}}/orders"
          }
        },
        {
          "name": "Get order by ID (not found)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/orders/nonexistent"
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "orderId",
      "value": ""
    }
  ]
}
