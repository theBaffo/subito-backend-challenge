                "exec": [
                  "pm.test('Status code is 404', () => {",
                  "    pm.response.to.have.status(404);",
                  "});",
                  "pm.test('Response contains error field', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('error');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Order by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/orders/{{orderId}}",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "orders", "{{orderId}}"]
            },
            "description": "Retrieves an order by ID. Run **Create Order** first — the `orderId` variable is populated automatically by its test script."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response has required fields', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.all.keys('id', 'status', 'created_at', 'items', 'total_price', 'total_vat');",
                  "});",
                  "pm.test('Order ID matches request', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.id).to.eql(pm.environment.get('orderId'));",
                  "});"
                ]
              }
